# ========================================
# ASHNEX AGROTRADE - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your configuration
# ========================================

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# MongoDB Configuration
# For development (local): mongodb://localhost:27017/
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_URI=mongodb://localhost:27017/
MONGO_DB_NAME=ashnex_agrotrade

# Admin API Key (Change this in production!)
ADMIN_API_KEY=admin_key_change_in_production

# Email Configuration (for sending notifications)
# EMAIL_PROVIDER=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password

# Frontend Configuration
FRONTEND_URL=http://localhost:8080

# Security
SECRET_KEY=your_secret_key_change_in_production
